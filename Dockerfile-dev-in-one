FROM node:24

ENV HOME=/root

ENV TERM=xterm-256color \
    BUN_INSTALL=/usr/local \
    UV_INSTALL_DIR=/usr/bin \
    LANG=en_US.UTF-8 \
    LANGUAGE=en_US:en \
    LC_ALL=en_US.UTF-8 \
    PATH="/usr/local/bin/:${PATH}"

# 设置 bash 为默认 shell
RUN ln -sf /bin/bash /bin/sh

# APT安装各种包
# 将apt-get源更换为清华的镜像
# RUN sed -i 's|http://deb.debian.org/|https://mirrors.tuna.tsinghua.edu.cn/|g' /etc/apt/sources.list.d/debian.sources
# 将apt-get源更换为阿里云的镜像
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources
RUN apt update && apt install -y \
        # Python 环境依赖
        python3 python3-pip python3-venv python3-dev python3-full \
        python3-setuptools python3-wheel pipx \
        # C++/Rust 编译依赖
        build-essential g++ clang libssl-dev pkg-config make cmake gdb valgrind \
        # Go 依赖
        gosu \
        # 数据库客户端
        postgresql-client \
        mariadb-client \
        redis-tools \
        # 图片视频处理工具
        ffmpeg \
        imagemagick \
        # SSH工具
        openssh-server \
        openssh-client \
        # 其他常用工具
        git \
        nano \
        procps ca-certificates locales \
        jq socat tini \
        curl wget telnet iputils-ping net-tools unzip zip sudo && \
    # 清理 apt 缓存
    apt-get purge -y --auto-remove && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN sed -i 's/^# *en_US.UTF-8 UTF-8$/en_US.UTF-8 UTF-8/' /etc/locale.gen && \
    locale-gen && \
    # update-locale 在部分 slim 基础镜像中会返回 invalid locale settings，这里改为直接写入默认 locale 配置
    printf 'LANG=en_US.UTF-8\nLANGUAGE=en_US:en\nLC_ALL=en_US.UTF-8\n' > /etc/default/locale

# 安装 uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# NodeJS相关
RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g \
        bun \
        ts-node \
        pm2 \
        pnpm \
        node-gyp \
        n \
        typescript && \
    n download 22 && \
    n download 16 && \
    n prune

ENV NODE_PATH=/usr/local/lib/node_modules \
    NODE_ENV=production \
    PATH="/usr/local/lib/node_modules/.bin:${PATH}"

# Java相关
RUN curl -s https://get.sdkman.io | bash && \
    chmod a+x "$HOME/.sdkman/bin/sdkman-init.sh" && \
    source "$HOME/.sdkman/bin/sdkman-init.sh" && \
    sdk install java 8.0.482-tem && \
    sdk install java 17.0.19-tem && \
    sdk install java 21.0.11-tem && \
    sdk install java 25.0.3-tem && \
    sdk install java 26-tem && \
    sdk install maven && \
    sdk install gradle && \
    sdk default java 26-tem && \
    sdk flush archives && \
    sdk flush temp

ENV SDKMAN_DIR=$HOME/.sdkman
ENV JAVA_HOME=$SDKMAN_DIR/candidates/java/current
ENV MAVEN_HOME=$SDKMAN_DIR/candidates/maven/current
ENV GRADLE_HOME=$SDKMAN_DIR/candidates/gradle/current
ENV PATH=$JAVA_HOME/bin:$MAVEN_HOME/bin:$GRADLE_HOME/bin:$PATH

# Rust相关
#RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh && \
#    source "$HOME/.cargo/env" && \
#    # 安装 Rust 开发工具
#    cargo install -y rustfmt-nightly clippy rust-gdb

# ssh服务相关
RUN sed -i 's/^#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    mkdir /run/sshd && \
    chmod 0755 /run/sshd && \
    chown root:root /run/sshd

COPY init-sshd.sh $HOME/
RUN chmod 755 $HOME/init-sshd.sh
COPY init-dev-in-one.sh $HOME/
RUN chmod 755 $HOME/init-dev-in-one.sh

COPY dev-in-one.pm2.json $HOME/dev-in-one.pm2.json

# 暴露端口
EXPOSE 22

# 设置工作目录为 home
WORKDIR /root/workspace

CMD ["sh", "-c", "pm2-runtime start $HOME/dev-in-one.pm2.json"]
