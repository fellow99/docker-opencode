{
  "apps": [
    {
      "name": "init-vnc",
      "script": "/root/init-vnc.sh",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": false
    },
    {
      "name": "init-sdkman",
      "script": "/root/init-sdkman.sh",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": false
    },
    {
      "name": "playwright",
      "script": "npx @playwright/mcp@latest --host $PLAYWRIGHT_HOST --port $PLAYWRIGHT_PORT --allowed-hosts 'localhost:$PLAYWRIGHT_PORT,127.0.0.1:$PLAYWRIGHT_PORT' --executable-path $PLAYWRIGHT_EXECUTABLE_PATH --user-data-dir $PLAYWRIGHT_USER_DIR --no-sandbox",
      "env": {
        "PLAYWRIGHT_HOST": "0.0.0.0",
        "PLAYWRIGHT_PORT": "8931",
        "PLAYWRIGHT_EXECUTABLE_PATH": "/usr/bin/chromium",
        "PLAYWRIGHT_USER_DIR": "/root/user-data"
      },
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true
    },
    {
      "name": "opencode",
      "script": "opencode serve --hostname $OPENCODE_HOSTNAME --port $OPENCODE_PORT",
      "env": {
        "OPENCODE_HOSTNAME": "0.0.0.0",
        "OPENCODE_PORT": "4096"
      },
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true
    },
    {
      "name": "openclaw",
      "script": "openclaw gateway run",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true
    }
  ]
}
