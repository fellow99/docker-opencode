# browser-sandbox: Playwright MCP server with VNC browser preview
FROM node:24

ENV HOME=/root

# Set display environment
ENV DISPLAY=:99

ENV TERM=xterm-256color \
    BUN_INSTALL=/usr/local \
    UV_INSTALL_DIR=/usr/bin \
    NODE_PATH=/usr/local/lib/node_modules \
    LANG=en_US.UTF-8 \
    LANGUAGE=en_US:en \
    LC_ALL=en_US.UTF-8 \
    NODE_ENV=production \
    PATH="/usr/local/bin/:/usr/local/lib/node_modules/.bin:${PATH}"

# PLAYWRIGHT environment
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Install dependencies for Playwright browsers and display/VNC
RUN apt-get update && apt-get install -y \
    # Playwright browser dependencies
    chromium \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    libatspi2.0-0 \
    libxshmfence1 \
    # Display and VNC
    xvfb \
    x11vnc \
    novnc \
    websockify \
    fluxbox \
    # Python 环境依赖
    python3 python3-pip python3-venv python3-dev python3-full \
    python3-setuptools python3-wheel pipx \
    # Rust 编译依赖
    build-essential libssl-dev pkg-config \
    git \
    # Utilities
    procps \
    ca-certificates \
    curl \
    ffmpeg \
    fonts-liberation \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
    gosu \
    jq \
    locales \
    openssh-server \
    openssh-client \
    socat \
    tini \
    imagemagick \
    socat \
    tini \
    wget telnet iputils-ping net-tools unzip zip sudo && \
    # 清理 apt 缓存
    apt-get purge -y --auto-remove && \
	apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN sed -i 's/^# *en_US.UTF-8 UTF-8$/en_US.UTF-8 UTF-8/' /etc/locale.gen && \
    locale-gen && \
    # update-locale 在部分 slim 基础镜像中会返回 invalid locale settings，这里改为直接写入默认 locale 配置
    printf 'LANG=en_US.UTF-8\nLANGUAGE=en_US:en\nLC_ALL=en_US.UTF-8\n' > /etc/default/locale

# 安装 uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Install Playwright MCP globally
RUN npm install -g \
	bun \
	pm2 \
	pnpm \
	node-gyp \
	playwright playwright-extra puppeteer-extra-plugin-stealth \
	@playwright/cli @playwright/mcp @playwright/test

# 设置 bash 为默认 shell
RUN ln -sf /bin/bash /bin/sh

# ssh服务相关
RUN sed -i 's/^#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    mkdir /run/sshd && \
    chmod 0755 /run/sshd && \
    chown root:root /run/sshd

COPY init-sshd.sh $HOME/
RUN chmod 755 $HOME/init-sshd.sh

COPY init-vnc.sh $HOME/
RUN chmod 755 $HOME/init-vnc.sh

COPY playwright-vnc.pm2.json $HOME/playwright-vnc.pm2.json

# 暴露端口
EXPOSE 22 8931 6080

# 设置工作目录为 home
WORKDIR /root/workspace

# Create browser data directory
RUN mkdir -p /root/user-data

# Volume for persistent browser data
VOLUME /root/user-data

CMD ["sh", "-c", "pm2-runtime start $HOME/playwright-vnc.pm2.json"]
